# ==========================================
# Application Configuration
# ==========================================
PROJECT_NAME="BinWise API"
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=replace_this_with_a_secure_random_string_32_chars_min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ==========================================
# PostGIS Database Settings
# ==========================================
POSTGRES_USER=binwise_admin
POSTGRES_PASSWORD=binwise_secure_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=binwise_db
# Async connection URL used by FastAPI / SQLAlchemy
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==========================================
# Cache & Message Broker (Redis)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ==========================================
# Celery Asynchronous Workers
# ==========================================
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# ==========================================
# Hardware / Telemetry Security
# ==========================================
# Secret header token required from SIM800L pings
TELEMETRY_API_KEY=binwise_gsm_node_secret_key_2026

# ==========================================
# AI Route Engine Defaults
# ==========================================
DEFAULT_OVERFLOW_THRESHOLD_PCT=80.0
DEFAULT_COLLECTION_VEHICLE_CAPACITY=10